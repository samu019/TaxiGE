<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Iniciar sesión - TaxiGE</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #111827;
            color: #111827;
        }

        .login-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .login-card {
            background: white;
            width: 100%;
            max-width: 420px;
            border-radius: 18px;
            padding: 32px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.25);
        }

        h1 {
            margin-top: 0;
            font-size: 28px;
        }

        p {
            color: #6b7280;
        }

        label {
            display: block;
            margin-top: 16px;
            font-weight: bold;
        }

        input {
            width: 100%;
            padding: 13px;
            margin-top: 6px;
            border: 1px solid #d1d5db;
            border-radius: 10px;
            box-sizing: border-box;
        }

        button {
            width: 100%;
            margin-top: 24px;
            padding: 14px;
            border: 0;
            border-radius: 12px;
            background: #111827;
            color: white;
            font-weight: bold;
            cursor: pointer;
        }

        .error {
            background: #fee2e2;
            color: #991b1b;
            padding: 12px;
            border-radius: 10px;
            margin-bottom: 16px;
        }
    </style>
</head>
<body>

<div class="login-wrapper">
    <div class="login-card">
        <h1>TaxiGE Platform</h1>
        <p>Accede a tu panel privado de gestión de taxis.</p>

        {% if form.errors %}
            <div class="error">
                Usuario o contraseña incorrectos.
            </div>
        {% endif %}

        <form method="post">
            {% csrf_token %}

            <label>Usuario</label>
            {{ form.username }}

            <label>Contraseña</label>
            {{ form.password }}

            <button type="submit">Entrar</button>
        </form>
    </div>
</div>

</body>
</html>
