<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Panel del dueño de taxi - TaxiGE</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f4f6f8;
            color: #111827;
        }

        .header {
            background: #111827;
            color: white;
            padding: 20px 40px;
        }

        .header h1 {
            margin: 0;
            font-size: 26px;
        }

        .header p {
            margin: 8px 0 0;
            color: #d1d5db;
        }

        .container {
            padding: 30px 40px;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 16px;
            margin-bottom: 30px;
        }

        .card {
            background: white;
            border-radius: 14px;
            padding: 20px;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
        }

        .card h3 {
            margin: 0 0 8px;
            font-size: 15px;
            color: #6b7280;
        }

        .card strong {
            font-size: 30px;
        }

        .section {
            background: white;
            border-radius: 14px;
            padding: 24px;
            margin-bottom: 24px;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
        }

        .section h2 {
            margin-top: 0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            text-align: left;
            padding: 12px;
            border-bottom: 1px solid #e5e7eb;
        }

        th {
            color: #6b7280;
            font-size: 14px;
        }

        .empty {
            color: #6b7280;
        }

        @media (max-width: 900px) {
            .cards {
                grid-template-columns: repeat(2, 1fr);
            }

            .container {
                padding: 20px;
            }
        }
    </style>
</head>
<body>

<div class="header">
    <h1>Panel privado del dueño de taxi</h1>
    <p>Gestiona tus taxis, conductores, pagos y daños desde TaxiGE Platform.</p>
</div>

<div class="container">

    <div class="cards">
        <div class="card">
            <h3>Empresas</h3>
            <strong>{{ companies_count }}</strong>
        </div>

        <div class="card">
            <h3>Taxis</h3>
            <strong>{{ vehicles_count }}</strong>
        </div>

        <div class="card">
            <h3>Conductores</h3>
            <strong>{{ drivers_count }}</strong>
        </div>

        <div class="card">
            <h3>Pagos</h3>
            <strong>{{ payments_count }}</strong>
        </div>

        <div class="card">
            <h3>Daños</h3>
            <strong>{{ damages_count }}</strong>
        </div>
    </div>

    <div class="section">
        <h2>Últimos pagos</h2>

        {% if recent_payments %}
            <table>
                <thead>
                    <tr>
                        <th>Conductor</th>
                        <th>Taxi</th>
                        <th>Fecha</th>
                        <th>Esperado</th>
                        <th>Pagado</th>
                        <th>Deuda</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    {% for payment in recent_payments %}
                        <tr>
                            <td>{{ payment.driver.full_name }}</td>
                            <td>{{ payment.vehicle.plate_number }}</td>
                            <td>{{ payment.payment_date }}</td>
                            <td>{{ payment.expected_amount }} XAF</td>
                            <td>{{ payment.paid_amount }} XAF</td>
                            <td>{{ payment.debt_amount }} XAF</td>
                            <td>{{ payment.get_status_display }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p class="empty">Todavía no hay pagos registrados.</p>
        {% endif %}
    </div>

    <div class="section">
        <h2>Últimos daños</h2>

        {% if recent_damages %}
            <table>
                <thead>
                    <tr>
                        <th>Taxi</th>
                        <th>Conductor</th>
                        <th>Daño</th>
                        <th>Fecha</th>
                        <th>Costo estimado</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    {% for damage in recent_damages %}
                        <tr>
                            <td>{{ damage.vehicle.plate_number }}</td>
                            <td>{{ damage.driver.full_name }}</td>
                            <td>{{ damage.title }}</td>
                            <td>{{ damage.damage_date }}</td>
                            <td>{{ damage.estimated_cost }} XAF</td>
                            <td>{{ damage.get_status_display }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p class="empty">Todavía no hay daños registrados.</p>
        {% endif %}
    </div>

</div>

</body>
</html>
