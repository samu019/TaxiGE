    .topbar {
        padding: 10px 12px !important;
        min-height: auto !important;
    }

    .brand-wrap {
        gap: 8px !important;
    }

    .brand-logo {
        width: 34px !important;
        height: 34px !important;
        border-radius: 11px !important;
        font-size: 13px !important;
    }

    .brand {
        font-size: 15px !important;
    }

    .brand small {
        display: none !important;
    }

    .top-actions {
        gap: 6px !important;
    }

