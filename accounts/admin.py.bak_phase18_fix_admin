@admin.register(AdminRequest)
class AdminRequestAdmin(admin.ModelAdmin):
    list_display = (
        'id',
        'company_name',
        'owner_full_name',
        'user',
        'phone',
        'city',
        'taxi_count',
        'status',
        'created_at',
    )

    list_filter = (
        'status',
        'city',
        'created_at',
    )

    search_fields = (
        'company_name',
        'owner_full_name',
        'phone',
        'user__username',
        'user__email',
    )

    readonly_fields = (
        'user',
        'company_name',
        'owner_full_name',
        'phone',
        'city',
        'taxi_count',
        'message',
        'document',
        'created_at',
        'updated_at',
        'reviewed_by',
        'reviewed_at',
    )

    actions = ['approve_requests', 'reject_requests']

    def approve_requests(self, request, queryset):
        for admin_request in queryset.filter(status='pending'):
            user = admin_request.user
            user.role = User.ROLE_ADMIN
            user.admin_approved = True
            user.is_staff = False
            user.is_superuser = False
            user.save()

            admin_request.status = AdminRequest.STATUS_APPROVED
            admin_request.reviewed_by = request.user
            admin_request.reviewed_at = timezone.now()
            admin_request.review_note = 'Solicitud aprobada desde el panel principal.'
            admin_request.save()

        self.message_user(request, 'Solicitudes aprobadas correctamente.')

    approve_requests.short_description = 'Aprobar solicitudes seleccionadas'

    def reject_requests(self, request, queryset):
        for admin_request in queryset.filter(status='pending'):
            admin_request.status = AdminRequest.STATUS_REJECTED
            admin_request.reviewed_by = request.user
            admin_request.reviewed_at = timezone.now()
            admin_request.review_note = 'Solicitud rechazada desde el panel principal.'
            admin_request.save()

        self.message_user(request, 'Solicitudes rechazadas correctamente.')

    reject_requests.short_description = 'Rechazar solicitudes seleccionadas'
